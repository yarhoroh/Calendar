{
  "name": "calendar",
  "version": "0.2.10",
  "description": "Calendar with notes — desktop app",
  "main": "./out/main/index.js",
  "author": "Calendar",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --win",
    "geticon": "node gen-icon.cjs"
  },
  "build": {
    "appId": "com.calendar.app",
    "productName": "Calendar",
    "publish": [
      {
        "provider": "github",
        "owner": "yarhoroh",
        "repo": "Calendar"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/@lydell/node-pty/**"
    ],
    "files": [
      "**/*",
      "!**/node_modules/@lydell/node-pty/prebuilds/darwin-*/**",
      "!**/node_modules/@lydell/node-pty/prebuilds/linux-*/**",
      "!**/node_modules/@lydell/node-pty/prebuilds/win32-arm64/**",
      "!**/node_modules/@lydell/node-pty/third_party/conpty/*/win10-arm64/**"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/tts",
        "to": "tts"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "better-sqlite3": "^12.10.1",
    "electron-updater": "^6.8.9",
    "protobufjs": "^8.6.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sherpa-onnx-node": "^1.13.3",
    "tar-stream": "^3.2.0",
    "unbzip2-stream": "^1.4.3",
    "ws": "^8.21.0"
  }
}
